{
  "name": "glyphling",
  "version": "0.1.1-beta.1",
  "description": "A Node + TypeScript + Ink terminal pet that accompanies Claude Code sessions.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "glyphling": "dist/src/bin.js"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "!dist/**/*.test.*",
    "dist/claude-commands/*.md",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "dev": "GLYPHLING_HOME=./.dev-state/dev tsx src/cli.tsx",
    "demo": "GLYPHLING_HOME=./.dev-state/demo tsx src/cli.tsx",
    "test": "GLYPHLING_HOME=./.dev-state/test vitest run",
    "test:watch": "GLYPHLING_HOME=./.dev-state/test vitest",
    "build": "tsc -p tsconfig.build.json && chmod +x dist/src/bin.js && cp -r claude-commands dist/claude-commands",
    "typecheck": "tsc --noEmit",
    "demo:lint": "bash scripts/check-tapes.sh",
    "demo:record": "bash scripts/record-demo.sh",
    "prepublishOnly": "npm test",
    "prepack": "rm -rf dist && npm run build"
  },
  "dependencies": {
    "chokidar": "^5.0.0",
    "ink": "^5.1.0",
    "proper-lockfile": "^4.1.2",
    "react": "^18.3.1",
    "ulid": "^3.0.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/proper-lockfile": "^4.1.4",
    "@types/react": "^18.3.1",
    "audit-ci": "^7.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RR-AMATOK/Claude-Hatch.git"
  },
  "bugs": {
    "url": "https://github.com/RR-AMATOK/Claude-Hatch/issues"
  },
  "homepage": "https://github.com/RR-AMATOK/Claude-Hatch#readme",
  "keywords": ["claude-code", "statusline", "tamagotchi", "cli", "tui", "ink", "pet"]
}
